{
  "permissions": {
    "allow": [
      "Bash(bash:*)",
      "Bash(git:*)",
      "Bash(node:*)",
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[TOOL] Bash: $TOOL_INPUT\" >> .claude/logs/tool-audit.log 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[TOOL] Write/Edit: $TOOL_INPUT\" >> .claude/logs/tool-audit.log 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "understand-anything@understand-anything": true
  }
}
